# Shared environment for all dev stacks.

POSTGRES_DB=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# NATS from dev/infra.yml, reachable via the external `dev` network
NATS_URL=nats://nats:4222

# Required by service-bootstrap. Placeholders so services boot in dev —
# point these at a real collector/Alertmanager/Grafana once one exists.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
ALERTMANAGER_URL=http://localhost
GRAFANA_TRACING_URI=http://localhost

# Public origin the frontends are served from (WebAuthn rp_origin).
# In dev this is traefik on plain http://localhost — a secure context,
# so passkeys work without TLS.
PUBLIC_ORIGIN=http://localhost
